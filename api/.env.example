# Parakh API — Environment Variables
# Copy this file to .env and fill in your keys

# Groq API (free) — https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Gemini API (free) — https://aistudio.google.com
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace API (free) — https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# Redis (local Docker or Railway)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:3000,https://parakh.vercel.app
RATE_LIMIT_PER_MIN=30
